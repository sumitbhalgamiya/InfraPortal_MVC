@using MVCSecurityDemo.Models
@model LoginViewModel
@{
    ViewBag.Title = "Login";
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }

    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px;
    }

    .login-card {
        width: 100%;
        max-width: 450px;
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        overflow: hidden;
    }

    .login-header {
        background: #4f46e5;
        color: white;
        text-align: center;
        padding: 25px;
    }

        .login-header h2 {
            margin: 0;
            font-weight: 600;
        }

    .login-body {
        padding: 30px;
    }

    .form-control {
        height: 45px;
        border-radius: 8px;
        border: 1px solid #ced4da;
    }

        .form-control:focus {
            box-shadow: none;
            border-color: #4f46e5;
        }

    .btn-login {
        background: #4f46e5;
        color: white;
        border: none;
        height: 45px;
        border-radius: 8px;
        font-weight: 600;
        width: 100%;
    }

        .btn-login:hover {
            background: #4338ca;
            color: white;
        }

    .register-link {
        text-align: center;
        margin-top: 20px;
    }

        .register-link a {
            color: #4f46e5;
            font-weight: 600;
            text-decoration: none;
        }

    .checkbox label {
        margin-left: 5px;
        font-weight: normal;
    }

    .text-danger {
        font-size: 13px;
    }
</style>

<div class="login-container">
    <div class="login-card">

        <div class="login-header">
            <h2>Welcome</h2>
            <p style="margin-top:10px;">Sign in to continue</p>
        </div>

        <div class="login-body">

            @using (Html.BeginForm("Login", "Account",
                new { ReturnUrl = ViewBag.ReturnUrl },
                FormMethod.Post,
                new { role = "form" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="form-group mb-3">
                    <label>Email Address</label>
                    @Html.TextBoxFor(m => m.Email,
                        new
                        {
                            @class = "form-control",
                            placeholder = "Enter your email"
                        })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="form-group mb-3">
                    <label>Password</label>
                    @Html.PasswordFor(m => m.Password,
                        new
                        {
                            @class = "form-control",
                            placeholder = "Enter your password"
                        })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                @*<div class="form-group mb-3">
                    <div class="checkbox">
                        @Html.CheckBoxFor(m => m.RememberMe)
                        @Html.LabelFor(m => m.RememberMe)
                    </div>
                </div>*@

                <button type="submit" class="btn btn-login">
                    Login
                </button>

                <div class="register-link">
                    @Html.ActionLink("Create New Account", "Register")
                </div>
            }

        </div>

    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}