@{
    ViewBag.Title = "Home Page";
}

<style>
    .home-container {
        min-height: calc(100vh - 120px);
        padding: 50px 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .hero-section {
        background: rgba(255,255,255,0.98);
        border-radius: 20px;
        padding: 70px 50px;
        text-align: center;
        box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        margin-bottom: 40px;
    }

    .hero-title {
        font-size: 48px;
        font-weight: 700;
        color: #4f46e5;
        margin-bottom: 15px;
    }

    .hero-subtitle {
        font-size: 18px;
        color: #6b7280;
        margin-bottom: 35px;
    }

    .btn-custom {
        background: #4f46e5;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 30px;
        font-size: 16px;
        font-weight: 600;
        transition: all .3s ease;
    }

    .btn-custom:hover {
        background: #4338ca;
        color: white;
        text-decoration: none;
    }

    .feature-card {
        background: #fff;
        border-radius: 15px;
        padding: 30px;
        text-align: center;
        height: 100%;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
        transition: all .3s ease;
    }

    .feature-card:hover {
        transform: translateY(-5px);
    }

    .feature-icon {
        font-size: 45px;
        margin-bottom: 15px;
    }

    .feature-title {
        font-size: 22px;
        font-weight: 600;
        color: #333;
        margin-bottom: 12px;
    }

    .feature-text {
        color: #6b7280;
        line-height: 1.6;
    }

    .stats-section {
        margin-top: 40px;
    }

    .stats-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
    }

    .stats-number {
        font-size: 32px;
        font-weight: 700;
        color: #4f46e5;
    }

    .stats-label {
        color: #6b7280;
        margin-top: 5px;
    }

    @@media(max-width:768px) {
        .hero-title {
            font-size: 36px;
        }

        .hero-section {
            padding: 40px 25px;
        }
    }
</style>

<div class="home-container">

    <div class="container">

        <div class="hero-section">

            <h1 class="hero-title">
                Welcome to Security Management
            </h1>

            <p class="hero-subtitle">
                Secure Authentication, User Management and Modern version
            </p>

            <a href="@Url.Action("Register","Account")"
               class="btn btn-custom">
                Get Started
            </a>

        </div>

        <div class="row">

            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-icon">🔐</div>
                    <div class="feature-title">Secure Login</div>
                    <div class="feature-text">
                        Authentication and authorization features.
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-icon">👥</div>
                    <div class="feature-title">User Management</div>
                    <div class="feature-text">
                        Manage users, roles and permissions efficiently.
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="feature-card">
                    <div class="feature-icon">⚡</div>
                    <div class="feature-title">High Performance</div>
                    <div class="feature-text">
                        Optimized architecture.
                    </div>
                </div>
            </div>

        </div>

        <div class="row stats-section">

            <div class="col-md-3 col-sm-6">
                <div class="stats-card">
                    <div class="stats-number">100%</div>
                    <div class="stats-label">Secure</div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="stats-card">
                    <div class="stats-number">24/7</div>
                    <div class="stats-label">Availability</div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="stats-card">
                    <div class="stats-number">99+</div>
                    <div class="stats-label">Users</div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6">
                <div class="stats-card">
                    <div class="stats-number">Best</div>
                    <div class="stats-label">Framework</div>
                </div>
            </div>

        </div>

    </div>

</div>